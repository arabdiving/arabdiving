# ===================================================
# ArabDiving - Environment Variables
# انسخ هذا الملف إلى .env وعدّل القيم
# ===================================================

# المنفذ (Render يضبطه تلقائياً - لا تغيّره)
PORT=3000

# رابط قاعدة بيانات MongoDB Atlas
# احصل عليه من: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/arabdiving?retryWrites=true&w=majority

# مفتاح سري للجلسات (اكتب أي نص طويل عشوائي)
JWT_SECRET=arabdiving-super-secret-key-change-this-2026

# بيانات أول حساب أدمن (ستُستخدم عند تشغيل npm run seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ArabDiving@2026
ADMIN_NAME=المشرف العام

# GA4 Measurement ID
GA_ID=G-01KE2TK0NH
